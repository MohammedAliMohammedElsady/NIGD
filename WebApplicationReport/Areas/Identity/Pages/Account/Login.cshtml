@page
@model LoginModel
@using Microsoft.AspNetCore.Localization
@{
    ViewData["Title"] = "Log in";
    Layout = null;
    var culture = HttpContext.Features.Get<IRequestCultureFeature>()?.RequestCulture.Culture.Name ?? "en";
    var isArabic = culture.StartsWith("ar");
    var dir = isArabic ? "rtl" : "ltr";
    var returnUrl = HttpContext.Request.Path + HttpContext.Request.QueryString;
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – National Institute for Development</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            background-color: #0a0a0f;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        /* circuit-board corner decorations */
        .corner {
            position: fixed;
            width: 160px;
            height: 60px;
            border: 2px solid #1e2a3a;
        }
        .corner::after {
            content: '';
            display: block;
            width: 8px;
            height: 8px;
            background: #3a8fd4;
            border-radius: 50%;
            margin-top: 24px;
        }
        .corner.tl { top: 40px; left: 40px; border-right: none; border-bottom: none; }
        .corner.tl::after { margin-left: auto; margin-right: -5px; }
        .corner.tr { top: 40px; right: 40px; border-left: none; border-bottom: none; }
        .corner.tr::after { margin-left: -5px; }
        .corner.bl { bottom: 40px; left: 40px; border-right: none; border-top: none; }
        .corner.bl::after { margin-top: -5px; margin-left: auto; margin-right: -5px; }
        .corner.br { bottom: 40px; right: 40px; border-left: none; border-top: none; }
        .corner.br::after { margin-top: -5px; margin-left: -5px; }

        .card-login {
            background: #111318;
            border: 1px solid #1e2a3a;
            border-radius: 16px;
            padding: 48px 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 0 60px rgba(30, 80, 160, 0.15);
        }

        .logo-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 28px;
        }

        .logo-icon {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #0d1b2a;
            border: 2px solid #2a4a7f;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: #3a8fd4;
        }

        h1.title {
            color: #ffffff;
            font-size: 1.5rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 6px;
        }

        .subtitle {
            color: #6b7280;
            font-size: 0.82rem;
            text-align: center;
            margin-bottom: 32px;
            line-height: 1.5;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 16px;
        }

        .input-group-custom .icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #4b5563;
            font-size: 15px;
        }

        .input-group-custom input {
            width: 100%;
            background: #1a1d24;
            border: 1px solid #2a3040;
            border-radius: 10px;
            color: #e5e7eb;
            padding: 13px 14px 13px 40px;
            font-size: 0.9rem;
            transition: border-color .2s;
        }

        .input-group-custom input:focus {
            outline: none;
            border-color: #3a8fd4;
            background: #1e2230;
        }

        .input-group-custom input::placeholder { color: #4b5563; }

        .remember {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 24px;
            color: #9ca3af;
            font-size: 0.85rem;
        }

        .remember input[type=checkbox] { accent-color: #3a8fd4; width: 15px; height: 15px; }

        .btn-login {
            width: 100%;
            padding: 13px;
            background: #2563eb;
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
        }

        .btn-login:hover { background: #1d4ed8; }

        .text-danger { color: #f87171 !important; font-size: 0.82rem; margin-bottom: 12px; display: block; }

        .validation-error {
            color: #f87171;
            font-size: 0.78rem;
            margin-top: 4px;
        }

        .lang-switcher {
            position: fixed;
            top: 18px;
            right: 24px;
            display: flex;
            gap: 8px;
            z-index: 100;
        }

        .lang-btn {
            background: #1a1d24;
            border: 1px solid #2a3040;
            border-radius: 8px;
            color: #9ca3af;
            font-size: 0.8rem;
            padding: 6px 14px;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s;
        }

        .lang-btn:hover, .lang-btn.active {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }
    </style>
</head>
<body>

    <div class="corner tl"></div>
    <div class="corner tr"></div>
    <div class="corner bl"></div>
    <div class="corner br"></div>

    @* Language switcher *@
    <div class="lang-switcher">
        <a href="/Language/Set?culture=en&returnUrl=@returnUrl" class="lang-btn @(!isArabic ? "active" : "")">🇬🇧 EN</a>
        <a href="/Language/Set?culture=ar&returnUrl=@returnUrl" class="lang-btn @(isArabic ? "active" : "")">🇸🇦 AR</a>
    </div>

    <div class="card-login">

        <div class="logo-wrap">
            <div class="logo-icon">⊙</div>
        </div>

        <h1 class="title">@(isArabic ? "مرحباً بعودتك" : "Welcome Back")</h1>
        <p class="subtitle">@(isArabic ? "المعهد القومي للحوكمة والتنمية المستدامة" : "National Institute for Governance and Sustainable Development")</p>

        <form id="account" method="post">
            <span asp-validation-summary="ModelOnly" class="text-danger"></span>

            <div class="input-group-custom">
                <span class="icon">✉</span>
                <input asp-for="Input.Email"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="@(isArabic ? "البريد الإلكتروني" : "Email address")" />
                <span asp-validation-for="Input.Email" class="validation-error"></span>
            </div>

            <div class="input-group-custom">
                <span class="icon">🔒</span>
                <input asp-for="Input.Password"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder="@(isArabic ? "كلمة المرور" : "Password")" />
                <span asp-validation-for="Input.Password" class="validation-error"></span>
            </div>

            <div class="remember">
                <input asp-for="Input.RememberMe" type="checkbox" />
                <label asp-for="Input.RememberMe">@(isArabic ? "تذكرني" : "Remember me")</label>
            </div>

            <button id="login-submit" type="submit" class="btn-login">
                @(isArabic ? "تسجيل الدخول" : "Login")
            </button>
        </form>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
