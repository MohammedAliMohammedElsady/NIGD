@{
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
    var dir = isArabic ? "rtl" : "ltr";
    var bootstrapRtl = isArabic ? "bootstrap.rtl.min.css" : "bootstrap.min.css";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(isArabic ? "المعهد القومي للحوكمة" : "NIGD")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/@bootstrapRtl" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplicationReport.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand-logo {
            height: 38px;
            width: auto;
            margin-inline-end: 8px;
        }
        .navbar-brand-text {
            font-weight: 700;
            font-size: 0.95rem;
            color: #1a3c6e !important;
            font-family: 'Tahoma', sans-serif;
        }
        .nav-username {
            color: #6b7280 !important;
            font-size: 0.85rem;
            padding-inline: 10px;
            cursor: default;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="Logo" class="navbar-brand-logo"
                         onerror="this.style.display='none'" />
                    <span class="navbar-brand-text">
                        @(isArabic ? "المعهد القومي للحوكمة" : "NIGD")
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1"></ul>

                    <ul class="navbar-nav align-items-center">
                        @* Language switcher *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown">
                                🌐 @ViewLocalizer["Language"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Language" asp-action="Set"
                                       asp-route-culture="en" asp-route-returnUrl="@returnUrl">
                                        🇬🇧 @ViewLocalizer["English"]
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Language" asp-action="Set"
                                       asp-route-culture="ar" asp-route-returnUrl="@returnUrl">
                                        🇸🇦 @ViewLocalizer["Arabic"]
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-2">
        <div class="container text-center" style="font-size:0.82rem;">
            &copy; 2026 &mdash; @(isArabic ? "المعهد القومي للحوكمة والتنمية المستدامة" : "National Institute for Governance & Sustainable Development")
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
