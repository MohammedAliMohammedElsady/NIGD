@model WebApplicationReport.Models.ViewModels.ReportCreateViewModel
@using WebApplicationReport.Models.Domain
@{
    ViewData["Title"] = "Create Report";
}

<style>
    .cr-wrap { max-width: 820px; margin: 0 auto; }

    .cr-header {
        background: linear-gradient(135deg, #1a3c6e 0%, #2563eb 100%);
        border-radius: 16px 16px 0 0;
        padding: 24px 32px;
        color: white;
    }

    .cr-header h2 { margin: 0; font-size: 1.4rem; font-weight: 700; }
    .cr-header .sub { font-size: 0.82rem; opacity: .7; margin-top: 4px; }

    .cr-body {
        background: #fff;
        border-radius: 0 0 16px 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.09);
        padding: 32px;
    }

    .section-label {
        font-size: 0.73rem;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 16px;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #374151;
        margin-bottom: 6px;
    }

    .form-control, .form-select {
        border: 1.5px solid #e5e7eb;
        border-radius: 9px;
        padding: 10px 14px;
        font-size: 0.9rem;
        transition: border-color .2s, box-shadow .2s;
    }

    .form-control:focus, .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
        outline: none;
    }

    .field-divider {
        border: none;
        border-top: 1px solid #f1f4fb;
        margin: 24px 0;
    }

    .fields-section {
        background: #fafbff;
        border: 1px solid #e8ecf5;
        border-radius: 14px;
        padding: 20px;
    }

    .fields-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .fields-toolbar .title {
        font-weight: 700;
        font-size: 0.9rem;
        color: #1a3c6e;
    }

    .btn-add-field {
        background: #eff6ff;
        color: #2563eb;
        border: 1.5px solid #bfdbfe;
        border-radius: 8px;
        padding: 7px 16px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
    }

    .btn-add-field:hover { background: #dbeafe; }

    .field-row {
        background: #fff;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 10px;
        position: relative;
    }

    .field-row:hover { border-color: #c7d2fe; }

    .btn-remove-field {
        position: absolute;
        top: 10px;
        inset-inline-end: 10px;
        background: #fee2e2;
        color: #dc2626;
        border: none;
        border-radius: 6px;
        width: 26px;
        height: 26px;
        font-size: 0.8rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .15s;
    }

    .btn-remove-field:hover { background: #fecaca; }

    .form-control-sm, .form-select-sm {
        border: 1.5px solid #e5e7eb;
        border-radius: 7px;
        font-size: 0.82rem;
        padding: 6px 10px;
    }

    .form-control-sm:focus, .form-select-sm:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 2px rgba(37,99,235,0.1);
        outline: none;
    }

    .form-check-input:checked { background-color: #2563eb; border-color: #2563eb; }

    .no-fields-msg {
        text-align: center;
        padding: 24px;
        color: #9ca3af;
        font-size: 0.85rem;
    }

    .btn-save {
        background: linear-gradient(135deg, #1a3c6e, #2563eb);
        color: white;
        border: none;
        border-radius: 9px;
        padding: 10px 28px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: opacity .2s;
    }

    .btn-save:hover { opacity: .9; color: white; }

    .btn-cancel {
        background: #f3f4f6;
        color: #6b7280;
        border: none;
        border-radius: 9px;
        padding: 10px 24px;
        font-weight: 500;
        font-size: 0.9rem;
        text-decoration: none;
    }

    .btn-cancel:hover { background: #e5e7eb; color: #374151; }
</style>

<div class="cr-wrap mt-4">
    <div class="cr-header">
        <h2>📋 @ViewLocalizer["Create Report"]</h2>
        <div class="sub">@ViewLocalizer["Define the report structure and its fields"]</div>
    </div>

    <div class="cr-body">
        <form asp-action="Create" method="post" id="reportForm">

            <div class="section-label">Report Info</div>

            <div class="mb-3">
                <label class="form-label">@ViewLocalizer["Report Name"] <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" required placeholder="e.g. Monthly Report" />
            </div>

            <div class="mb-4">
                <label class="form-label">@ViewLocalizer["Description"]</label>
                <textarea asp-for="Description" class="form-control" rows="2"
                          placeholder="@ViewLocalizer["Optional description..."]"></textarea>
            </div>

            <hr class="field-divider" />

            <div class="fields-section">
                <div class="fields-toolbar">
                    <span class="title">📐 @ViewLocalizer["Fields"]</span>
                    <button type="button" class="btn-add-field" onclick="addField()">
                        ＋ @ViewLocalizer["Add Field"]
                    </button>
                </div>
                <div id="fieldsContainer">
                    <div class="no-fields-msg" id="noFieldsMsg">
                        📭 @ViewLocalizer["No fields yet. Click Add Field."]
                    </div>
                </div>
            </div>

            <hr class="field-divider" />

            <div class="d-flex gap-3 align-items-center">
                <button type="submit" class="btn-save">✓ @ViewLocalizer["Save Report"]</button>
                <a asp-action="Index" class="btn-cancel">✕ @ViewLocalizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    let fieldIndex = 0;

    function addField() {
        const msg = document.getElementById('noFieldsMsg');
        if (msg) msg.remove();
        const container = document.getElementById('fieldsContainer');
        const i = fieldIndex++;

        const div = document.createElement('div');
        div.className = 'field-row';
        div.id = `field_${i}`;
        div.innerHTML = `
            <button type="button" class="btn-remove-field" onclick="removeField(${i})">✕</button>
            <div class="row g-2 align-items-end" style="padding-inline-end:36px">
                <div class="col-md-4">
                    <label class="form-label" style="font-size:.78rem;font-weight:600;color:#374151;">Label *</label>
                    <input type="text" name="Fields[${i}].Label" class="form-control form-control-sm" required
                           placeholder="Field name" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" style="font-size:.78rem;font-weight:600;color:#374151;">Type</label>
                    <select name="Fields[${i}].FieldType" class="form-select form-select-sm"
                            onchange="toggleOptions(this, ${i})">
                        <option value="0">Text</option>
                        <option value="1">Number</option>
                        <option value="2">Date</option>
                        <option value="3">Dropdown</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Fields[${i}].IsRequired"
                               value="true" id="req_${i}" />
                        <label class="form-check-label" for="req_${i}"
                               style="font-size:.8rem;color:#374151;">Required</label>
                    </div>
                </div>
                <div class="col-md-3 options-col" id="opts_${i}" style="display:none">
                    <label class="form-label" style="font-size:.78rem;font-weight:600;color:#374151;">Options</label>
                    <input type="text" name="Fields[${i}].Options" class="form-control form-control-sm"
                           placeholder="Yes,No,Maybe" />
                </div>
            </div>`;
        container.appendChild(div);
    }

    function removeField(i) {
        document.getElementById(`field_${i}`)?.remove();
    }

    function toggleOptions(select, i) {
        const opts = document.getElementById(`opts_${i}`);
        opts.style.display = select.value === '3' ? 'block' : 'none';
    }
</script>
}
