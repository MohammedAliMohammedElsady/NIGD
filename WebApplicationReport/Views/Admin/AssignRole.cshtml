@model WebApplicationReport.Models.ViewModels.AssignRoleViewModel
@{
    ViewData["Title"] = ViewLocalizer["Assign Role"];
    var initials = Model.Email?.Length > 0 ? Model.Email[0].ToString().ToUpper() : "?";

    var roleIcons = new Dictionary<string, string>
    {
        ["Admin"]     = "👑",
        ["Editor"]    = "✏️",
        ["DataEntry"] = "📝"
    };

    var roleDescriptions = new Dictionary<string, string>
    {
        ["Admin"]     = "Full access — manage users, reports, and all data",
        ["Editor"]    = "Can edit and delete entries",
        ["DataEntry"] = "Can add and view entries only"
    };

    var roleColors = new Dictionary<string, string[]>
    {
        ["Admin"]     = new[] { "#fef3c7", "#f59e0b", "#92400e", "#f59e0b" },
        ["Editor"]    = new[] { "#d1fae5", "#10b981", "#065f46", "#10b981" },
        ["DataEntry"] = new[] { "#dbeafe", "#3b82f6", "#1e40af", "#3b82f6" }
    };
}

<style>
    .ar-wrap { max-width: 540px; margin: 0 auto; }

    .ar-header {
        background: linear-gradient(135deg, #1a3c6e 0%, #2563eb 100%);
        border-radius: 16px 16px 0 0;
        padding: 24px 32px;
        color: white;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .ar-avatar {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        border: 2px solid rgba(255,255,255,0.4);
        font-size: 1.4rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ar-header h2 { margin: 0; font-size: 1.35rem; font-weight: 700; }
    .ar-header .email { font-size: 0.82rem; opacity: .72; margin-top: 3px; word-break: break-all; }

    .ar-body {
        background: #fff;
        border-radius: 0 0 16px 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.09);
        padding: 28px 32px;
    }

    .section-label {
        font-size: 0.73rem;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 16px;
    }

    .role-card {
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px 18px;
        margin-bottom: 12px;
        cursor: pointer;
        transition: border-color .2s, background .2s, transform .1s;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        position: relative;
    }

    .role-card:hover {
        transform: translateX(2px);
        border-color: #c7d2fe;
        background: #fafbff;
    }

    .role-card.selected { border-color: var(--rc-border); background: var(--rc-bg); }

    .role-card input[type=checkbox] {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }

    .role-check-box {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        border: 2px solid #d1d5db;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 1px;
        transition: all .2s;
        background: white;
        font-size: 0.75rem;
        color: white;
    }

    .role-card.selected .role-check-box {
        background: var(--rc-check);
        border-color: var(--rc-check);
    }

    .role-icon {
        font-size: 1.6rem;
        flex-shrink: 0;
        line-height: 1;
    }

    .role-info { flex-grow: 1; }

    .role-name {
        font-weight: 700;
        font-size: 0.95rem;
        color: #111827;
        margin-bottom: 3px;
    }

    .role-card.selected .role-name { color: var(--rc-text); }

    .role-desc {
        font-size: 0.78rem;
        color: #6b7280;
        line-height: 1.4;
    }

    .field-divider {
        border: none;
        border-top: 1px solid #f1f4fb;
        margin: 20px 0;
    }

    .btn-save {
        background: linear-gradient(135deg, #1a3c6e, #2563eb);
        color: white;
        border: none;
        border-radius: 9px;
        padding: 10px 28px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: opacity .2s, transform .2s;
    }

    .btn-save:hover { opacity: .9; transform: translateY(-1px); color: white; }

    .btn-cancel {
        background: #f3f4f6;
        color: #6b7280;
        border: none;
        border-radius: 9px;
        padding: 10px 24px;
        font-weight: 500;
        font-size: 0.9rem;
        text-decoration: none;
    }

    .btn-cancel:hover { background: #e5e7eb; color: #374151; }

    .selection-hint {
        font-size: 0.78rem;
        color: #9ca3af;
        margin-bottom: 14px;
    }
</style>

<div class="ar-wrap mt-4">
    <div class="ar-header">
        <div class="ar-avatar">@initials</div>
        <div>
            <h2>🔑 @ViewLocalizer["Assign Role"]</h2>
            <div class="email">@Model.Email</div>
        </div>
    </div>

    <div class="ar-body">
        <form asp-action="AssignRole" method="post" id="assignForm">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Email" />

            <div class="section-label">Select Roles</div>
            <div class="selection-hint">You can assign multiple roles to this user.</div>

            @foreach (var role in Model.AllRoles)
            {
                var isSelected = Model.SelectedRoles.Contains(role);
                var icon = roleIcons.ContainsKey(role) ? roleIcons[role] : "🎭";
                var desc = roleDescriptions.ContainsKey(role) ? roleDescriptions[role] : role;
                var colors = roleColors.ContainsKey(role)
                    ? roleColors[role]
                    : new[] { "#f3f4f6", "#6b7280", "#374151", "#6b7280" };

                <label class="role-card @(isSelected ? "selected" : "")"
                       id="card_@role"
                       style="--rc-bg:@colors[0]; --rc-border:@colors[1]; --rc-text:@colors[2]; --rc-check:@colors[3];"
                       onclick="toggleRole('@role')">
                    <input type="checkbox"
                           name="SelectedRoles"
                           value="@role"
                           id="role_@role"
                           @(isSelected ? "checked" : "") />
                    <div class="role-check-box" id="chk_@role">
                        @if (isSelected) { <text>✓</text> }
                    </div>
                    <div class="role-icon">@icon</div>
                    <div class="role-info">
                        <div class="role-name">@role</div>
                        <div class="role-desc">@desc</div>
                    </div>
                </label>
            }

            <hr class="field-divider" />

            <div class="d-flex gap-3 align-items-center">
                <button type="submit" class="btn-save">✓ @ViewLocalizer["Save"]</button>
                <a asp-action="Users" class="btn-cancel">✕ @ViewLocalizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleRole(role) {
        const cb   = document.getElementById('role_' + role);
        const card = document.getElementById('card_' + role);
        const chk  = document.getElementById('chk_' + role);

        cb.checked = !cb.checked;

        if (cb.checked) {
            card.classList.add('selected');
            chk.innerHTML = '✓';
        } else {
            card.classList.remove('selected');
            chk.innerHTML = '';
        }
    }
</script>
