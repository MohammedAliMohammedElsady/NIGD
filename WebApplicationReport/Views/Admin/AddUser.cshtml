@model WebApplicationReport.Models.ViewModels.AddUserViewModel
@{
    ViewData["Title"] = ViewLocalizer["Add User"];
}

<style>
    .form-page-wrap {
        max-width: 560px;
        margin: 0 auto;
    }

    .form-header {
        background: linear-gradient(135deg, #1a3c6e 0%, #2563eb 100%);
        border-radius: 16px 16px 0 0;
        padding: 24px 32px;
        color: white;
    }

    .form-header h2 { margin: 0; font-size: 1.4rem; font-weight: 700; }
    .form-header .sub { font-size: 0.83rem; opacity: .7; margin-top: 4px; }

    .form-card {
        background: #fff;
        border-radius: 0 0 16px 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.09);
        padding: 32px;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #374151;
        margin-bottom: 6px;
    }

    .form-control, .form-select {
        border: 1.5px solid #e5e7eb;
        border-radius: 9px;
        padding: 10px 14px;
        font-size: 0.9rem;
        color: #111827;
        transition: border-color .2s, box-shadow .2s;
    }

    .form-control:focus, .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
        outline: none;
    }

    .input-icon-wrap {
        position: relative;
    }

    .input-icon-wrap .icon {
        position: absolute;
        top: 50%;
        inset-inline-start: 12px;
        transform: translateY(-50%);
        font-size: 1rem;
        pointer-events: none;
        opacity: .5;
    }

    .input-icon-wrap .form-control,
    .input-icon-wrap .form-select {
        padding-inline-start: 36px;
    }

    .btn-save {
        background: linear-gradient(135deg, #1a3c6e, #2563eb);
        color: white;
        border: none;
        border-radius: 9px;
        padding: 10px 28px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: opacity .2s, transform .2s;
    }

    .btn-save:hover { opacity: .9; transform: translateY(-1px); color: white; }

    .btn-cancel {
        background: #f3f4f6;
        color: #6b7280;
        border: none;
        border-radius: 9px;
        padding: 10px 24px;
        font-weight: 500;
        font-size: 0.9rem;
        text-decoration: none;
        transition: background .2s;
    }

    .btn-cancel:hover { background: #e5e7eb; color: #374151; }

    .field-divider {
        border: none;
        border-top: 1px solid #f1f4fb;
        margin: 20px 0;
    }

    .role-option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border: 1.5px solid #e5e7eb;
        border-radius: 9px;
        cursor: pointer;
        transition: border-color .2s, background .2s;
        margin-bottom: 8px;
    }

    .role-option:hover { border-color: #2563eb; background: #f8faff; }
    .role-option input[type=radio] { accent-color: #2563eb; }
</style>

<div class="form-page-wrap mt-4">
    <div class="form-header">
        <h2>➕ @ViewLocalizer["Add User"]</h2>
        <div class="sub">@ViewLocalizer["Create a new user account and assign a role"]</div>
    </div>

    <div class="form-card">
        <form asp-action="AddUser" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3" style="font-size:.88rem;"></div>

            <div class="mb-3">
                <label class="form-label">📧 @ViewLocalizer["Email"]</label>
                <div class="input-icon-wrap">
                    <input asp-for="Email" class="form-control" placeholder="user@example.com" autocomplete="off" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <hr class="field-divider" />

            <div class="mb-3">
                <label class="form-label">🔒 @ViewLocalizer["Password"]</label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">🔒 @ViewLocalizer["Confirm Password"]</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <hr class="field-divider" />

            <div class="mb-4">
                <label class="form-label">🎭 @ViewLocalizer["Role"]</label>
                <select asp-for="Role" class="form-select">
                    <option value="">-- @ViewLocalizer["No Role"] --</option>
                    @foreach (var role in Model.AllRoles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
            </div>

            <div class="d-flex gap-3 align-items-center">
                <button type="submit" class="btn-save">✓ @ViewLocalizer["Save"]</button>
                <a asp-action="Users" class="btn-cancel">✕ @ViewLocalizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
